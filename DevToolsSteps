package framework.devtools;

import com.codeborne.selenide.WebDriverRunner;

import org.openqa.selenium.chrome.ChromeDriver;

import org.openqa.selenium.devtools.DevTools;
import org.openqa.selenium.devtools.HasDevTools;

import org.openqa.selenium.devtools.v146.network.Network;

import org.openqa.selenium.devtools.v146.network.model.*;

import java.util.Map;
import java.util.Optional;
import java.util.concurrent.*;

public class DevToolsSteps {

    private final DevTools devTools;

    public DevToolsSteps() {

        ChromeDriver driver =
                (ChromeDriver) WebDriverRunner.getWebDriver();

        devTools = ((HasDevTools) driver).getDevTools();

        devTools.createSession();

        devTools.send(
                Network.enable(
                        Optional.empty(),
                        Optional.empty(),
                        Optional.empty()
                )
        );
    }

    public NetworkCaptureResult captureRequest(
            String partialUrl,
            Runnable action
    ) {

        CompletableFuture<NetworkCaptureResult> future =
                new CompletableFuture<>();

        ConcurrentHashMap<RequestId, Request> requests =
                new ConcurrentHashMap<>();

        ConcurrentHashMap<RequestId, Response> responses =
                new ConcurrentHashMap<>();

        /*
         * REQUEST
         */
        devTools.addListener(
                Network.requestWillBeSent(),
                event -> {

                    Request request = event.getRequest();

                    String url = request.getUrl();

                    /*
                     * Фильтруем URL
                     */
                    if (!url.contains(partialUrl)) {
                        return;
                    }

                    /*
                     * Игнорируем preflight
                     */
                    if ("OPTIONS".equalsIgnoreCase(request.getMethod())) {
                        return;
                    }

                    requests.put(
                            event.getRequestId(),
                            request
                    );
                }
        );

        /*
         * RESPONSE RECEIVED
         */
        devTools.addListener(
                Network.responseReceived(),
                event -> {

                    RequestId requestId = event.getRequestId();

                    if (!requests.containsKey(requestId)) {
                        return;
                    }

                    responses.put(
                            requestId,
                            event.getResponse()
                    );
                }
        );

        /*
         * LOADING FINISHED
         *
         * Только тут response body гарантированно существует
         */
        devTools.addListener(
                Network.loadingFinished(),
                event -> {

                    RequestId requestId = event.getRequestId();

                    if (!requests.containsKey(requestId)) {
                        return;
                    }

                    try {

                        Request request =
                                requests.get(requestId);

                        Response response =
                                responses.get(requestId);

                        String responseBody = "";

                        try {

                            responseBody =
                                    devTools.send(
                                            Network.getResponseBody(requestId)
                                    ).getBody();

                        } catch (Exception ex) {

                            responseBody =
                                    "FAILED_TO_READ_RESPONSE_BODY: "
                                            + ex.getMessage();
                        }

                        String requestBody =
                                request.getPostData()
                                        .orElse("");

                        NetworkCaptureResult result =
                                new NetworkCaptureResult(
                                        request.getUrl(),
                                        request.getMethod(),
                                        response.getStatus(),
                                        requestBody,
                                        responseBody,
                                        request.getHeaders(),
                                        response.getHeaders()
                                );

                        future.complete(result);

                    } catch (Exception e) {

                        future.completeExceptionally(e);
                    }
                }
        );

        /*
         * Выполняем UI действие
         */
        action.run();

        try {

            return future.get(30, TimeUnit.SECONDS);

        } catch (TimeoutException e) {

            throw new RuntimeException(
                    "Не дождались network события для url: "
                            + partialUrl,
                    e
            );

        } catch (Exception e) {

            throw new RuntimeException(e);
        }
    }
}
